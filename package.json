{
  "name": "draupnir",
  "version": "0.1.0",
  "description": "Draupnir - AI Service Management Platform built on Bifrost AI Gateway",
  "type": "module",
  "workspaces": ["packages/*"],
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "dev:debug": "NODE_OPTIONS='--inspect-brk' bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --format esm --target bun --external @gravito/atlas",
    "start": "bun dist/index.js",
    "test": "bun test src tests packages",
    "test:watch": "bun test src tests packages --watch",
    "test:coverage": "bun test --coverage",
    "test:unit": "bun test tests/Unit/",
    "test:sdk": "bun test packages/bifrost-sdk/",
    "test:integration": "bun test src --filter integration",
    "test:feature": "bun test tests/Feature/",
    "test:user": "bun test tests/ --filter User",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src tests packages",
    "lint:fix": "biome lint src tests packages --fix",
    "format": "biome format src tests packages --write",
    "format:check": "biome format src tests packages --check",
    "check": "bun run typecheck && bun run lint && bun run test",
    "verify": "bun run check && echo '✅ All checks passed!' && echo '' && echo '📊 Coverage report generated in ./coverage'",
    "setup": "bun install && bash scripts/setup-hooks.sh && bun run verify",
    "troubleshoot": "bash scripts/troubleshoot.sh",
    "generate:module": "bun scripts/generate-module.ts",
    "setup:hooks": "bash scripts/setup-hooks.sh",
    "migrate": "bun orbit migrate",
    "migrate:rollback": "bun orbit migrate:rollback",
    "migrate:fresh": "bun orbit migrate:fresh",
    "migrate:status": "bun orbit migrate:status",
    "seed": "bun orbit seed",
    "db:fresh": "bun orbit migrate:fresh && bun orbit seed",
    "db:doctor": "bun orbit doctor",
    "make:migration": "bun orbit make:migration",
    "make:model": "bun orbit make:model",
    "make:controller": "bun gravito make:controller",
    "make:middleware": "bun gravito make:middleware",
    "make:command": "bun gravito make:command",
    "route:list": "bun gravito route:list",
    "tinker": "bun gravito tinker",
    "generate:types": "bun orbit generate:types",
    "dev:frontend": "vite",
    "build:frontend": "vite build",
    "preview:frontend": "vite preview",
    "dev:all": "bun run dev & bun run dev:frontend",
    "typecheck:frontend": "tsc --project tsconfig.frontend.json --noEmit",
    "check:no-mock-in-src": "! grep -r 'MockGatewayClient' src/ --include='*.ts' -l | grep -v '__tests__' | grep -v 'LLMGateway'"
  },
  "dependencies": {
    "@gravito/atlas": "^2.0.0",
    "@gravito/core": "^3.0.1",
    "@gravito/impulse": "^2.0.0",
    "@gravito/plasma": "^2.0.0",
    "@gravito/prism": "^3.1.1",
    "@gravito/sentinel": "^4.0.1",
    "@gravito/signal": "^3.1.0",
    "@gravito/stasis": "^3.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@inertiajs/react": "^3.0.3",
    "@libsql/client": "^0.17.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "jsonwebtoken": "^9.0.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "@gravito/core": "3.0.1",
    "@gravito/photon": "1.0.1",
    "@gravito/scaffold": "4.1.0",
    "@gravito/chromatic": "1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@gravito/pulse": "^3.4.0",
    "@playwright/test": "^1.48.0",
    "@draupnir/bifrost-sdk": "workspace:*",
    "@types/bun": "^1.3.10",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.4.27",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.9",
    "mongodb": "^7.1.1",
    "postcss": "^8.5.9",
    "tailwindcss": "3",
    "typescript": "^5.3.0",
    "vite": "^8.0.8",
    "vitest": "^4.0.18",
    "yaml": "^2.6.0"
  }
}
